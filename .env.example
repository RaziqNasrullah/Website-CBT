# ============================================
# CBT APP - ENVIRONMENT CONFIGURATION
# Copy file ini menjadi .env lalu sesuaikan nilainya
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Database (MySQL via XAMPP)
# Pastikan MySQL service di XAMPP Control Panel sudah running,
# dan database dengan nama DB_NAME sudah dibuat lewat phpMyAdmin.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cbt_app
DB_CONNECTION_LIMIT=10

# Auth / Security
JWT_SECRET=ganti_dengan_secret_key_yang_sangat_rahasia_dan_panjang
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=10

# Admin Default (digunakan oleh seed.js, hanya untuk inisialisasi pertama)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Administrator

# Email (SMTP Gmail - untuk mengirim kode OTP verifikasi registrasi)
# EMAIL_USER   -> alamat Gmail pengirim
# EMAIL_APP_PASSWORD -> App Password 16 digit dari akun Gmail tsb
#   Cara buat: Akun Google > Keamanan > Verifikasi 2 Langkah (aktifkan dulu) > App Passwords
EMAIL_USER=akun_pengirim@gmail.com
EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# OTP (verifikasi email saat registrasi)
OTP_EXPIRES_MINUTES=10
OTP_RESEND_COOLDOWN_MINUTES=3
